# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://turf_user:turf_password@localhost:5432/turf_war

# ─── JWT ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── Strava API ──────────────────────────────────────────────
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Must match the redirect URI registered in your Strava app settings
STRAVA_REDIRECT_URI=http://localhost:3001/api/auth/strava/callback

# ─── Strava Webhook (optional, for real-time sync) ───────────
# Generate with: openssl rand -hex 32
STRAVA_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# ─── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Mapbox (frontend) ───────────────────────────────────────
# Get your token at: https://account.mapbox.com/
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token

# ─── Backend API URL (frontend) ──────────────────────────────
VITE_API_URL=http://localhost:3001
